#!/usr/bin/env bash
# ============================================================
# backup-db — Automated PostgreSQL backup for InfraSignal
# ============================================================
# Usage:
#   ./bin/backup-db           # run manually
#   (also runs via cron at 3 AM daily)
#
# Backups are stored in /opt/backups/infrasignal/
# Keeps last 30 days of daily backups, auto-prunes older ones.
# ============================================================

set -euo pipefail

BACKUP_DIR="/opt/backups/infrasignal"
COMPOSE_FILE="/opt/infrasignal-v2/docker/docker-compose-prod.yml"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
KEEP_DAYS=30

mkdir -p "$BACKUP_DIR"

BACKUP_FILE="${BACKUP_DIR}/infrasignal_${TIMESTAMP}.sql.gz"

echo "[$(date)] Starting database backup..."

# Dump and compress
docker compose -f "$COMPOSE_FILE" exec -T db \
    pg_dump -U postgres infrasignal | gzip > "$BACKUP_FILE"

# Verify backup is not empty (minimum 1KB)
FILESIZE=$(stat -c%s "$BACKUP_FILE" 2>/dev/null || echo "0")
if [[ "$FILESIZE" -lt 1024 ]]; then
    echo "[$(date)] ERROR: Backup file too small (${FILESIZE} bytes), something went wrong!"
    rm -f "$BACKUP_FILE"
    exit 1
fi

echo "[$(date)] Backup complete: $BACKUP_FILE ($(du -h "$BACKUP_FILE" | cut -f1))"

# Prune old backups
PRUNED=$(find "$BACKUP_DIR" -name "infrasignal_*.sql.gz" -mtime +${KEEP_DAYS} -delete -print | wc -l)
if [[ "$PRUNED" -gt 0 ]]; then
    echo "[$(date)] Pruned $PRUNED backup(s) older than ${KEEP_DAYS} days"
fi

# Show backup summary
TOTAL=$(find "$BACKUP_DIR" -name "infrasignal_*.sql.gz" | wc -l)
TOTAL_SIZE=$(du -sh "$BACKUP_DIR" 2>/dev/null | cut -f1)
echo "[$(date)] Total backups: $TOTAL ($TOTAL_SIZE)"
