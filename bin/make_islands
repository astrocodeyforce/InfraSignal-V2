#!/bin/bash
# Build React island bundles for InfraSignal
# Output: web/cobrands/infrasignal/islands/
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
FRONTEND_DIR="$PROJECT_ROOT/frontend"

cd "$FRONTEND_DIR"

if [ ! -d "node_modules" ]; then
    echo "Installing frontend dependencies..."
    npm ci --production=false
fi

echo "Building React islands..."
npx vite build

echo "Island build complete. Output:"
ls -la "$PROJECT_ROOT/web/cobrands/infrasignal/islands/"
