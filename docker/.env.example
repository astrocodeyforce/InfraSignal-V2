# ============================================================
# InfraSignal — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in real values:
#   cp docker/.env.example docker/.env
#
# NEVER commit .env to git (it's in .gitignore)
# ============================================================

# --- Environment ---
# Which environment: dev | test | staging | production
ENVIRONMENT=dev

# --- Database ---
POSTGRES_PASSWORD=change_me_to_random_string
FMS_DB_USER=fms
FMS_DB_PASS=change_me_to_random_string
FMS_DB_NAME=infrasignal
FMS_DB_HOST=postgres.svc

# --- Admin ---
SUPERUSER_EMAIL=admin@infrasignal.local
SUPERUSER_PASSWORD=change_me_to_random_string

# --- SendGrid SMTP ---
SMTP_SMARTHOST=smtp.sendgrid.net
SMTP_TYPE=tls
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=SG.your_sendgrid_api_key_here

# --- OpenAI ---
OPENAI_API_KEY=sk-your_openai_key_here

# --- SightEngine ---
SIGHTENGINE_API_USER=your_user_id
SIGHTENGINE_API_SECRET=your_secret_here

# --- Google OIDC ---
GOOGLE_OIDC_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_OIDC_SECRET=your_secret_here

# --- Cloudflare Turnstile ---
TURNSTILE_SITE_KEY=your_site_key
TURNSTILE_SECRET_KEY=your_secret_key

# --- Domain (production/staging only) ---
DOMAIN=localhost
SSL_EMAIL=admin@infrasignal.org
